    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "# =========================================================\n",
    "# 1. 讀取最強的兩個單體預測檔\n",
    "# =========================================================\n",
    "# 請確認檔名與你們存檔的位置一致\n",
    "lasso = pd.read_csv(\"../submissions/linear_submission.csv\")\n",
    "# XGBoost\n",
    "xgb = pd.read_csv(\"../submissions/xgb_v2_submission.csv\") \n",
    "\n",
    "# =========================================================\n",
    "# 2. 定義簡單暴力的權重 \n",
    "# =========================================================\n",
    "W_LASSO = 0.65\n",
    "W_XGB = 0.35\n",
    "\n",
    "# =========================================================\n",
    "# 3. 在對數 (Log) 空間進行融合 (絕對不能在真實房價相加)\n",
    "# =========================================================\n",
    "lasso_log = np.log1p(lasso[\"SalePrice\"])\n",
    "xgb_log = np.log1p(xgb[\"SalePrice\"])\n",
    "\n",
    "ensemble_log = (W_LASSO * lasso_log) + (W_XGB * xgb_log)\n",
    "\n",
    "# =========================================================\n",
    "# 4. 還原為真實房價並存檔\n",
    "# =========================================================\n",
    "simple_blend = pd.DataFrame({\n",
    "    \"Id\": lasso[\"Id\"],\n",
    "    \"SalePrice\": np.expm1(ensemble_log)\n",
    "})\n",
    "\n",
    "os.makedirs(\"../submissions\", exist_ok=True)\n",
    "output_path = \"../submissions/simple_blend_submission.csv\"\n",
    "simple_blend.to_csv(output_path, index=False)\n",
    "\n",
    "print(f\"雙模型預測檔已存為 {output_path}\")"
>>>>>>> 5728817181a53b4d6f7ccd50d50507feeefd82bb
